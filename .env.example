# ─── StillAI · ejemplo de configuración ───────────────────────────────────────
# Copia este archivo a .env y rellena los valores. NUNCA subas el .env real al repo.

# ── IA (al menos una). El proveedor activo lo define AI_PROVIDER ──
GROQ_API_KEY=            # console.groq.com  (empieza con gsk_)
GEMINI_API_KEY=          # aistudio.google.com (empieza con AIza)
ANTHROPIC_API_KEY=       # console.anthropic.com (empieza con sk-ant-)
AI_PROVIDER=groq         # groq | gemini | claude

# ── Seguridad / despliegue ──
DEBUG=false              # true solo en desarrollo (muestra detalle de errores)
COOKIE_SECURE=false      # true en producción (requiere HTTPS) → cookies Secure + HSTS
REGISTRATION_OPEN=true   # false en producción para cerrar el registro abierto
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000   # dominios permitidos (CORS)

# ── Límites de subida ──
MAX_FILE_MB=25           # tamaño máximo por imagen
MAX_FILES=60             # máximo de imágenes por grupo

# Nota: el secreto de sesión se genera solo en el archivo .secret (gitignored).
